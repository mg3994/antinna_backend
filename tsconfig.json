{
	"compilerOptions": {
		"target": "ESNext",

		"outDir": "dist",
		"rootDir": "src",

		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"types": ["google-apps-script"]
	},
	"include": ["src/**/*.ts"]
}
